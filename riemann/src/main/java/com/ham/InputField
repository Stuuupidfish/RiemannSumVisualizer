public class InputField
{
    private double[] coord;
    private static final int WIDTH;
    private static final int HEIGHT;
    private String value;
    private boolean isActive;

    public InputField(int x, int y, int w, int h)
    {
        coord = {x,y};
        WIDTH = w;
        HEIGHT = h;
        value = null;
        isActive = false;
    }
}